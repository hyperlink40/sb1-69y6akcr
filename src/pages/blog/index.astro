---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';

// Sample blog posts data - in a real app, this would come from a CMS or markdown files
const blogPosts = [
  {
    title: "Getting Started with Astro: A Complete Guide",
    description: "Learn how to build fast, modern websites with Astro's innovative island architecture and zero-JS by default approach.",
    date: "2025-01-15",
    category: "Web Development",
    slug: "getting-started-with-astro",
    readingTime: "8 min read",
    image: "https://images.pexels.com/photos/177598/pexels-photo-177598.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "Modern JavaScript ES2024 Features You Should Know",
    description: "Explore the latest JavaScript features including pattern matching, temporal API, and more exciting additions to the language.",
    date: "2025-01-12",
    category: "JavaScript",
    slug: "modern-javascript-es2024-features",
    readingTime: "12 min read",
    image: "https://images.pexels.com/photos/270348/pexels-photo-270348.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "Building Responsive Layouts with CSS Grid",
    description: "Master CSS Grid to create complex, responsive layouts with ease. Learn advanced techniques and best practices.",
    date: "2025-01-08",
    category: "CSS",
    slug: "building-responsive-layouts-css-grid",
    readingTime: "10 min read",
    image: "https://images.pexels.com/photos/196644/pexels-photo-196644.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "TypeScript Best Practices for Large Applications",
    description: "Learn how to structure and organize TypeScript code for scalable, maintainable large-scale applications.",
    date: "2025-01-05",
    category: "TypeScript",
    slug: "typescript-best-practices-large-applications",
    readingTime: "15 min read",
    image: "https://images.pexels.com/photos/574071/pexels-photo-574071.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "Web Performance Optimization Techniques",
    description: "Boost your website's performance with proven optimization strategies including code splitting, lazy loading, and more.",
    date: "2025-01-02",
    category: "Performance",
    slug: "web-performance-optimization-techniques",
    readingTime: "11 min read",
    image: "https://images.pexels.com/photos/590016/pexels-photo-590016.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "Introduction to Web Components",
    description: "Discover the power of Web Components and how they can help you build reusable, framework-agnostic UI elements.",
    date: "2024-12-28",
    category: "Web Components",
    slug: "introduction-to-web-components",
    readingTime: "9 min read",
    image: "https://images.pexels.com/photos/546819/pexels-photo-546819.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "React Server Components: The Future of React",
    description: "Explore how React Server Components are revolutionizing how we build React applications with better performance and developer experience.",
    date: "2024-12-25",
    category: "React",
    slug: "react-server-components-future",
    readingTime: "13 min read",
    image: "https://images.pexels.com/photos/1181671/pexels-photo-1181671.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "Building Accessible Web Applications",
    description: "Learn essential techniques for creating inclusive web applications that work for everyone, including users with disabilities.",
    date: "2024-12-22",
    category: "Accessibility",
    slug: "building-accessible-web-applications",
    readingTime: "14 min read",
    image: "https://images.pexels.com/photos/3184430/pexels-photo-3184430.jpeg?auto=compress&cs=tinysrgb&w=600"
  },
  {
    title: "GraphQL vs REST: Choosing the Right API Architecture",
    description: "Compare GraphQL and REST APIs to understand when to use each approach and how they impact your application's performance and developer experience.",
    date: "2024-12-19",
    category: "API Design",
    slug: "graphql-vs-rest-api-architecture",
    readingTime: "16 min read",
    image: "https://images.pexels.com/photos/325229/pexels-photo-325229.jpeg?auto=compress&cs=tinysrgb&w=600"
  }
];

// Categories for filtering
const categories = ["All", "Web Development", "JavaScript", "CSS", "TypeScript", "Performance", "React", "Accessibility", "API Design"];

// Get current page from URL params (for pagination)
const currentPage = 1;
const postsPerPage = 9;
const totalPages = Math.ceil(blogPosts.length / postsPerPage);

// Get posts for current page
const startIndex = (currentPage - 1) * postsPerPage;
const endIndex = startIndex + postsPerPage;
const currentPosts = blogPosts.slice(startIndex, endIndex);
---

<Layout title="Blog - DevBlog" description="Explore our collection of articles on web development, programming tutorials, and technology insights.">
  <Header />

  <main class="main-content">
    <div class="container">
      <div class="blog-header">
        <h1 class="blog-title">Blog</h1>
        <p class="blog-description">
          Discover the latest insights, tutorials, and best practices in web development and technology.
        </p>
      </div>

      <!-- Category Filter -->
      <div class="category-filter">
        <div class="filter-buttons">
          {categories.map(category => (
            <button
              class={`filter-btn ${category === "All" ? "active" : ""}`}
              data-category={category}
            >
              {category}
            </button>
          ))}
        </div>
      </div>

      <!-- Blog Posts Grid -->
      <div class="blog-grid" id="blog-grid">
        {currentPosts.map(post => (
          <BlogCard
            title={post.title}
            description={post.description}
            date={post.date}
            category={post.category}
            slug={post.slug}
            readingTime={post.readingTime}
            image={post.image}
          />
        ))}
      </div>

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="pagination">
          <button class="pagination-btn prev-btn" disabled={currentPage === 1}>
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Previous
          </button>

          <div class="pagination-numbers">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
              <button
                class={`pagination-number ${page === currentPage ? "active" : ""}`}
                data-page={page}
              >
                {page}
              </button>
            ))}
          </div>

          <button class="pagination-btn next-btn" disabled={currentPage === totalPages}>
            Next
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      )}

      <!-- Newsletter Section -->
      <section class="newsletter-section">
        <div class="newsletter-content">
          <h2 class="newsletter-title">Stay Updated</h2>
          <p class="newsletter-description">
            Get the latest articles and insights delivered straight to your inbox. No spam, unsubscribe at any time.
          </p>
          <form class="newsletter-form">
            <input
              type="email"
              placeholder="Enter your email address"
              class="newsletter-input"
              required
            />
            <button type="submit" class="newsletter-btn">Subscribe</button>
          </form>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .main-content {
    padding: 4rem 0;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-title {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #111827;
  }

  .blog-description {
    font-size: 1.25rem;
    color: #6b7280;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .category-filter {
    margin-bottom: 3rem;
    text-align: center;
  }

  .filter-buttons {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    background: white;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover {
    border-color: #2563eb;
    color: #2563eb;
  }

  .filter-btn.active {
    background: linear-gradient(135deg, #2563eb, #0891b2);
    border-color: #2563eb;
    color: white;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 5rem;
  }

  .pagination-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pagination-btn:hover:not(:disabled) {
    border-color: #2563eb;
    color: #2563eb;
  }

  .pagination-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pagination-numbers {
    display: flex;
    gap: 0.25rem;
  }

  .pagination-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    border-radius: 0.5rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pagination-number:hover {
    border-color: #2563eb;
    color: #2563eb;
  }

  .pagination-number.active {
    background: linear-gradient(135deg, #2563eb, #0891b2);
    border-color: #2563eb;
    color: white;
  }

  .newsletter-section {
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
    border-radius: 1rem;
    padding: 3rem;
    text-align: center;
  }

  .newsletter-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #111827;
  }

  .newsletter-description {
    font-size: 1.125rem;
    color: #6b7280;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .newsletter-form {
    display: flex;
    gap: 1rem;
    max-width: 400px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    font-size: 1rem;
    transition: border-color 0.2s ease;
  }

  .newsletter-input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .newsletter-btn {
    background: linear-gradient(135deg, #2563eb, #0891b2);
    color: white;
    border: none;
    padding: 0.875rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .newsletter-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  @media (max-width: 768px) {
    .main-content {
      padding: 2rem 0;
    }

    .blog-title {
      font-size: 2rem;
    }

    .blog-description {
      font-size: 1.125rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .filter-buttons {
      justify-content: center;
    }

    .pagination {
      flex-direction: column;
      gap: 1rem;
    }

    .pagination-numbers {
      order: -1;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .newsletter-section {
      padding: 2rem;
    }
  }
</style>

<script>
  // Category filtering functionality
  class BlogFilter {
    filterButtons: NodeListOf<Element>;
    blogCards: NodeListOf<Element>;

    constructor() {
      this.filterButtons = document.querySelectorAll('.filter-btn');
      this.blogCards = document.querySelectorAll('.blog-card');

      this.init();
    }

    init() {
      this.filterButtons.forEach((button: Element) => {
        button.addEventListener('click', (e: Event) => {
          const target = e.target as HTMLElement;
          const category = target.dataset.category;
          if (category) {
            this.filterPosts(category);
            this.updateActiveButton(target);
          }
        });
      });
    }

    filterPosts(category: string) {
      this.blogCards.forEach((card: Element) => {
        const cardElement = card as HTMLElement;
        const cardCategory = cardElement.dataset.category;
        if (category === 'All' || cardCategory === category) {
          cardElement.style.display = 'block';
        } else {
          cardElement.style.display = 'none';
        }
      });
    }

    updateActiveButton(activeButton: HTMLElement) {
      this.filterButtons.forEach((button: Element) => {
        button.classList.remove('active');
      });
      activeButton.classList.add('active');
    }
  }

  // Initialize filter functionality when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new BlogFilter();
  });
</script>
