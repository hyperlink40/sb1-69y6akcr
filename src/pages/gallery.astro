    init() {
      // Add click handlers to view buttons
      document.querySelectorAll('.view-btn').forEach((btn: Element) => {
        btn.addEventListener('click', (e: Event) => {
          const target = e.target as HTMLElement;
          const buttonElement = target.closest('.view-btn') as HTMLElement;
          const imageId = parseInt(buttonElement?.dataset.imageId || '0');
          this.openModal(imageId);
        });
      });

      // Close modal handlers
      this.closeBtn.addEventListener('click', () => this.closeModal());
      this.backdrop.addEventListener('click', () => this.closeModal());

      // Navigation handlers
      this.prevBtn.addEventListener('click', () => this.showPrevImage());
      this.nextBtn.addEventListener('click', () => this.showNextImage());

      // Keyboard navigation
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!this.modal.classList.contains('active')) return;

        switch (e.key) {
          case 'Escape':
            this.closeModal();
            break;
          case 'ArrowLeft':
            this.showPrevImage();
            break;
          case 'ArrowRight':
            this.showNextImage();
            break;
        }
      });
    }

    openModal(imageId: number) {
      const image = this.images.galleryImages.find(img => img.id === imageId);
      if (!image) return;

      this.currentImageIndex = this.images.galleryImages.findIndex(img => img.id === imageId);
      this.updateModalContent(image);
      this.modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    closeModal() {
      this.modal.classList.remove('active');
      document.body.style.overflow = '';
    }

    updateModalContent(image: typeof galleryImages[0]) {
      this.modalImage.src = image.src;
      this.modalImage.alt = image.alt;
      this.modalTitle.textContent = image.title;
      this.modalDescription.textContent = image.description;
    }

    showPrevImage() {
      this.currentImageIndex = (this.currentImageIndex - 1 + this.images.galleryImages.length) % this.images.galleryImages.length;
      const image = this.images.galleryImages[this.currentImageIndex];
      this.updateModalContent(image);
    }

    showNextImage() {
      this.currentImageIndex = (this.currentImageIndex + 1) % this.images.galleryImages.length;
      const image = this.images.galleryImages[this.currentImageIndex];
      this.updateModalContent(image);
    }
  }

  // Initialize functionality when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new GalleryFilter();
    new GalleryModal();
  });
</script>
